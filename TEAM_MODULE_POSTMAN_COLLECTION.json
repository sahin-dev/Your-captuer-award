{
  "info": {
    "name": "Team Module API",
    "description": "Postman collection for Team Module endpoints including team management, member operations, join requests, leaderboard, and auto-match system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Team Management",
      "item": [
        {
          "name": "Create Team",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "level",
                  "value": "Beginner",
                  "type": "text"
                },
                {
                  "key": "language",
                  "value": "English",
                  "type": "text"
                },
                {
                  "key": "country",
                  "value": "USA",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "A team of skilled players",
                  "type": "text"
                },
                {
                  "key": "accessibility",
                  "value": "PUBLIC",
                  "type": "text"
                },
                {
                  "key": "min_requirement",
                  "value": "5 members",
                  "type": "text"
                },
                {
                  "key": "badge",
                  "type": "file"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams"
              ]
            },
            "description": "Create a new team (Admin only). Includes badge file upload."
          },
          "response": []
        },
        {
          "name": "Get All Teams",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams"
              ]
            },
            "description": "Retrieve all teams"
          },
          "response": []
        },
        {
          "name": "Get Team Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/teams/:teamId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                ":teamId"
              ],
              "variable": [
                {
                  "key": "teamId",
                  "value": ""
                }
              ]
            },
            "description": "Get details of a specific team (Admin only)"
          },
          "response": []
        },
        {
          "name": "Update Team",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"level\": \"Intermediate\",\n  \"language\": \"English\",\n  \"country\": \"USA\",\n  \"description\": \"Updated team description\",\n  \"accessibility\": \"PRIVATE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/teams/:teamId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                ":teamId"
              ],
              "variable": [
                {
                  "key": "teamId",
                  "value": ""
                }
              ]
            },
            "description": "Update team details (Admin only)"
          },
          "response": []
        },
        {
          "name": "Delete Team",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/teams/:teamId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                ":teamId"
              ],
              "variable": [
                {
                  "key": "teamId",
                  "value": ""
                }
              ]
            },
            "description": "Delete a team (Admin only)"
          },
          "response": []
        }
      ]
    },
