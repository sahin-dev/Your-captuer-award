
model Product {
    id              String  @id @map("_id") @default(auto()) @db.ObjectId
    title           String
    category       Category
    items          items[]
    quantity        Int
    amount          Float
    currency        String
    icon            String?
    description     String?
    image           String?
    status ProductStatus @default(ACTIVE)

    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt

    @@map("products")
}

type items {
    type ProductType
    quantity Int
}

model Price {
    id      String          @id @map("_id")  @default(auto())  @db.ObjectId
    product_id      String  @db.ObjectId
    name            String
    amount          Float
    quantity        Int
    price_id        String

    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt
    @@map("prices")
    @@index([id,product_id])
}

enum Category {
    COINS
    BUNDLES
}

enum ProductStatus {
    ACTIVE
    INACTIVE
    DISCONTINUED
}

enum ProductType {
    COIN
    KEY
    BOOST   
    SWAP
}
