
model Product {
    id              String  @id @map("_id") @default(auto()) @db.ObjectId
    productType     ProductType
    title           String
    quantity        Int
    amount          Float
    currency        String  @default("USD")
    icon            String?
    description     String?
    image           String?
    status ProductStatus @default(ACTIVE)

    @@map("products")
    @@index([id,productType])
}

model Price {
    id      String          @id @map("_id")  @default(auto())  @db.ObjectId
    product_id      String  @db.ObjectId
    name            String
    amount          Float
    quantity        Int
    price_id        String

    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt
    @@map("prices")
    @@index([id,product_id])
}

enum ProductStatus {
    ACTIVE
    INACTIVE
    DISCONTINUED
}

enum ProductType {
    KEY
    BOOST   
    SWAP
}