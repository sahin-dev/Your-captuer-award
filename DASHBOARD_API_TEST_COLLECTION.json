// Thunder Client collection for Dashboard API endpoints
// Import this file into Thunder Client to test all endpoints

{
  "info": {
    "name": "Dashboard API - Admin Endpoints",
    "description": "All dashboard admin endpoints for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Payment & Transaction Endpoints",
      "item": [
        {
          "name": "1. Get Payment History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{local_url}}/dashboard/payments?page=1&limit=10",
              "host": ["{{local_url}}"],
              "path": ["dashboard", "payments"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "2. Get Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{local_url}}/dashboard/transactions?page=1&limit=19",
              "host": ["{{local_url}}"],
              "path": ["dashboard", "transactions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "19"
                }
              ]
            }
          }
        },
        {
          "name": "3. Get Transaction Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
