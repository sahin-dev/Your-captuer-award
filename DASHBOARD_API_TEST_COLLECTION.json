            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"userId\\\": \\\"6876137c34dacb19d4ab4479\\\"\\n}"
            },
            "url": {
              "raw": "{{local_url}}/dashboard/toggole-block",
